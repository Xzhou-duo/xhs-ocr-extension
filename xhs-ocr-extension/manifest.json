{
  "manifest_version": 3,
  "name": "小红书图片文字提取",
  "version": "1.0.1",
  "description": "在小红书网页版中，一键提取图片笔记里的文字内容并复制到剪贴板",
  "permissions": [
    "storage",
    "clipboardWrite"
  ],
  "host_permissions": [
    "*://www.xiaohongshu.com/*",
    "*://*.xhscdn.com/*",
    "*://*.xiaohongshu.com/*",
    "*://aip.baidubce.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://www.xiaohongshu.com/*"],
      "js": ["core_utils.js", "content_script.js"],
      "css": ["content_style.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
